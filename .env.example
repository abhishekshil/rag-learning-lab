# Copy to .env and adjust if needed. Defaults match docker-compose.yml.

# PostgreSQL + pgvector (LangChain PGVector)
POSTGRES_CONNECTION=postgresql+psycopg://raglab:raglab@localhost:5434/raglab

# Neo4j citation graph (LangChain Neo4jGraph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=raglab123

# MinIO S3-compatible blob storage (raw PDFs / images)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=raglab
MINIO_SECRET_KEY=raglab123
MINIO_BUCKET=papers
